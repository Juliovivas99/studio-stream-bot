## Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_target_channel_id_here
# Optional: set to register slash commands instantly for a single server (recommended for dev)
# DISCORD_GUILD_ID=your_server_id_here

## Alpaca Market Data (Stocks)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

## Alpaca WebSocket feed (free default)
# Options typically include: iex, sip, delayed_sip
ALPACA_FEED=iex

## Optional: override default symbols (comma-separated)
# SYMBOLS=AAPL,TSLA,NVDA

## Alerts (DM bot)
# Where alerts persist (JSON with atomic writes)
ALERTS_DB_PATH=data/alerts.json

# Default operator when user DMs `AAPL 250` (no explicit op)
ALERT_DEFAULT_OP=>=

# Allow alert commands in a guild channel (defaults to DM-only)
# If enabled, the bot will listen in `DISCORD_CHANNEL_ID` (if set).
# ALERTS_ALLOW_GUILD_MESSAGES=false

# Log verbosity: debug | info | warn | error
# LOG_LEVEL=info
